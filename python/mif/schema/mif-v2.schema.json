{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/varun29ankuS/mif-spec/schema/mif-v2.schema.json",
  "title": "Memory Interchange Format (MIF) v2.0",
  "description": "A vendor-neutral JSON schema for portable AI agent memories",
  "type": "object",
  "required": ["mif_version", "memories"],
  "properties": {
    "mif_version": {
      "type": "string",
      "pattern": "^2\\.",
      "description": "MIF specification version (any 2.x)"
    },
    "generator": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      },
      "required": ["name", "version"],
      "additionalProperties": true
    },
    "export_meta": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "created_at": { "type": "string", "format": "date-time" },
        "user_id": { "type": "string" },
        "checksum": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]+$" },
        "privacy": {
          "type": "object",
          "properties": {
            "pii_detected": { "type": "boolean" },
            "redacted_fields": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "memories": {
      "type": "array",
      "items": { "$ref": "#/$defs/memory" }
    },
    "knowledge_graph": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/knowledge_graph" }
      ]
    },
    "vendor_extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "memory": {
      "type": "object",
      "required": ["id", "content", "created_at"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier (UUID v4)"
        },
        "content": {
          "type": "string",
          "description": "Memory content text"
        },
        "memory_type": {
          "type": "string",
          "description": "Memory type (observation, decision, learning, error, context, conversation, or custom)"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/entity_reference" }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "embeddings": { "$ref": "#/$defs/embeddings" },
        "source": { "$ref": "#/$defs/source" },
        "parent_id": {
          "oneOf": [
            { "type": "string", "format": "uuid" },
            { "type": "null" }
          ]
        },
        "related_memory_ids": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" }
        },
        "agent_id": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "external_id": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "entity_reference": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "entity_type": {
          "type": "string",
          "description": "Entity type (person, organization, location, technology, concept, event, product, unknown, or custom)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "embeddings": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "dimensions": { "type": "integer", "minimum": 1 },
        "vector": {
          "type": "array",
          "items": { "type": "number" }
        },
        "normalized": { "type": "boolean" }
      },
      "required": ["model", "dimensions", "vector"],
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "properties": {
        "source_type": { "type": "string" },
        "session_id": { "type": "string" },
        "agent_name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "knowledge_graph": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph_entity" }
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/graph_relationship" }
        }
      },
      "additionalProperties": true
    },
    "graph_entity": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        },
        "summary": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "last_seen_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "graph_relationship": {
      "type": "object",
      "required": ["id", "source_entity_id", "target_entity_id", "relation_type"],
      "properties": {
        "id": { "type": "string" },
        "source_entity_id": { "type": "string" },
        "target_entity_id": { "type": "string" },
        "relation_type": { "type": "string" },
        "context": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "created_at": { "type": "string", "format": "date-time" },
        "invalidated_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
