{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.varun29ankus/mif-tools",
  "description": "Memory Interchange Format — convert, validate, and inspect AI agent memories across mem0, CrewAI, LangChain, and more",
  "repository": {
    "url": "https://github.com/varun29ankuS/mif-spec.git",
    "source": "github"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "pip",
      "identifier": "mif-tools[mcp]",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "runtime": "python",
      "arguments": ["-m", "mif.mcp_server"]
    }
  ]
}
